<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.OwnerToolsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:OwnerSubmitViewModel"
    Title="Gui POI"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">

            <Label Text="Chu dia diem"
                   Style="{StaticResource PageTitleLabel}" />

            <Label Text="Dien thong tin dia diem moi. Sau khi gui, diem o trang thai CHO DUYET — Admin se duyet tren Web."
                   Style="{StaticResource BodyText}" />

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Ma dia diem (code)"
                           Style="{StaticResource BodyText}" />
                    <Entry Text="{Binding Code}"
                           Placeholder="VD: OWN-CAFE-001"
                           Keyboard="Text" />

                    <Label Text="Ten tieng Anh *"
                           Style="{StaticResource BodyText}" />
                    <Entry Text="{Binding NameEn}"
                           Placeholder="English name"
                           Keyboard="Text" />

                    <Label Text="Ten tieng Viet (tuy chon)"
                           Style="{StaticResource BodyText}" />
                    <Entry Text="{Binding NameVi}"
                           Placeholder="Ten tieng Viet"
                           Keyboard="Text" />

                    <Label Text="Vi do (lat)"
                           Style="{StaticResource BodyText}" />
                    <Entry Text="{Binding Lat}"
                           Placeholder="10.7769"
                           Keyboard="Default" />

                    <Label Text="Kinh do (lng)"
                           Style="{StaticResource BodyText}" />
                    <Entry Text="{Binding Lng}"
                           Placeholder="106.7009"
                           Keyboard="Default" />

                    <Label Text="Ban kinh (m)"
                           Style="{StaticResource BodyText}" />
                    <Entry Text="{Binding Radius}"
                           Placeholder="50"
                           Keyboard="Numeric" />

                    <Button Text="Gui len he thong"
                            Command="{Binding SubmitCommand}" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center" />

                    <Label Text="{Binding StatusMessage}"
                           TextColor="{StaticResource BrandPrimaryDark}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
